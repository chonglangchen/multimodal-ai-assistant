# DeepSeek API Key (enables DeepSeek+BLIP hybrid vision mode)
# Supports any OpenAI-compatible API (DeepSeek官方 / 硅基流动 / 阿里云百炼 等)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com     # 默认 DeepSeek 官方
# DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1  # 硅基流动
# DEEPSEEK_MODEL=deepseek-chat                   # 默认模型，可按平台修改 

# Flask configuration
FLASK_SECRET_KEY=your_flask_secret_key_here

# File upload settings
UPLOAD_FOLDER=app/uploads
MAX_CONTENT_LENGTH=16000000 # 16MB

# Model Configuration (Optional - defaults are provided in model_manager.py)
# To override, uncomment and set the desired values:
# STT_MODEL=openai/whisper-tiny
# GEMINI_MODEL=gemini-2.5-flash-preview-05-20
# KOKORO_ASSETS_DIR=app/backend/kokoro_assets
# KOKORO_REPO_ID=hexgrad/Kokoro-82M